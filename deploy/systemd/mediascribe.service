[Unit]
Description=MediaScribe web application
After=network.target

[Service]
User=mediascribe
Group=mediascribe
WorkingDirectory=/opt/mediascribe/app
Environment=MEDIASCRIBE_DATA_DIR=/var/lib/mediascribe
Environment=MEDIASCRIBE_MODEL_DIR=/opt/mediascribe/models
ExecStart=/opt/mediascribe/app/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

